# ─────────────────────────────────────────────────────────────
# Required — LLM (OpenAI-compatible). Provider preferred in order:
#   OpenRouter (free, reliable tool-calling) > Groq > OpenAI.
# Set exactly one key; base URL + default model are auto-derived.
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=                   # https://openrouter.ai/keys (free) — primary
GROQ_API_KEY=                         # Groq free tier (note: weak supervisor handoffs)
OPENAI_API_KEY=                       # paid fallback
# Optional explicit overrides (otherwise derived from active provider):
LLM_BASE_URL=
DEFAULT_MODEL=

# ─────────────────────────────────────────────────────────────
# Required — Telegram
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # BotFather token
TELEGRAM_MODE=polling                 # polling (local, no tunnel) | webhook (production)

# ─────────────────────────────────────────────────────────────
# Required — LangSmith (free tier; enables token/cost dashboard)
# ─────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=                    # LangSmith API key
LANGCHAIN_PROJECT=agent-orch-platform

# ─────────────────────────────────────────────────────────────
# Optional — Tavily web search tool (researcher agent)
# ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=                       # if absent, web_search returns a graceful no-op

# ─────────────────────────────────────────────────────────────
# Optional — Google Stitch MCP
# ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=

# ─────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./agents.db
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
TELEGRAM_WEBHOOK_URL=https://<your-ngrok-url>/telegram/webhook   # webhook mode only
